{
  "name": "soundops-pro",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android",
    "build:android:local": "cd android && gradlew.bat assembleDebug -PreactNativeArchitectures=arm64-v8a",
    "build:android:local:all": "cd android && gradlew.bat assembleDebug",
    "build:android:release": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:android:release:all": "cd android && gradlew.bat assembleRelease",
    "build:android:preview": "eas build -p android --profile preview",
    "build:web": "expo export --platform web",
    "type-check": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-font": "~14.0.0",
    "expo-haptics": "~15.0.0",
    "expo-image": "~3.0.0",
    "expo-image-picker": "~17.0.0",
    "expo-linear-gradient": "~15.0.0",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "~31.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "typescript": "~5.9.2"
  },
  "private": true
}
