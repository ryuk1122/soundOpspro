{
  "expo": {
    "name": "SoundOps Pro",
    "slug": "soundops-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soundops",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Agregar fotos de tus equipos al inventario",
        "NSCameraUsageDescription": "Tomar fotos de tus equipos para el inventario"
      }
    },
    "android": {
      "package": "com.soundops.pro",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F1115"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1115"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Agregar fotos de tus equipos al inventario",
          "cameraPermission": "Tomar fotos de tus equipos para el inventario",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "cloudinaryCloudName": "dl2m6strc"
    }
  }
}
